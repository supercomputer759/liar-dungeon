[sub_resource type="Shader" id="Shader_vignette"]
code = "shader_type canvas_item;\nvoid fragment() {\n vec2 p = UV * 2.0 - 1.0;\n float edge = smoothstep(0.35, 1.25, length(p * vec2(0.82, 1.0)));\n COLOR = vec4(0.55, 0.0, 0.0, edge * 0.82);\n}"

[sub_resource type="ShaderMaterial" id="Material_vignette"]
